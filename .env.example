# PostgreSQL (local Docker, Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Required for Prisma migrate when using Supabase pooler on Vercel (see README).
# For Neon or a single direct URL, set DIRECT_URL to the same value as DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Example (local Docker): same connection for both
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lattice"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/lattice"
