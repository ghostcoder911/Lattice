# PostgreSQL (local Docker, Neon, Supabase, Vercel Postgres, etc.)
# One variable only. On Supabase + Vercel, use the Session pooler URI (port 5432) from
# Connect → ORM → Prisma (see README).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Example (local Docker):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lattice"
